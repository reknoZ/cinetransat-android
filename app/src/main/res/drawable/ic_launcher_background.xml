<?xml version="1.0" encoding="utf-8"?>
<!-- Full icon on the background layer (no launcher parallax zoom). 108dp canvas, logo in 66dp safe zone. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FEF9E2" />
        </shape>
    </item>
    <item
        android:width="58dp"
        android:height="58dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/cinetransat_logo" />
    </item>
</layer-list>
